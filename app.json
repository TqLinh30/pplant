{
  "expo": {
    "name": "Pplant",
    "slug": "pplant",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pplant",
    "userInterfaceStyle": "light",
    "ios": {
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F2F7F7",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": ["android.permission.CAMERA"],
      "package": "com.tranlinh30502.pplant"
    },
    "androidStatusBar": {
      "backgroundColor": "#F2F7F7",
      "barStyle": "dark-content",
      "translucent": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F2F7F7",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Pplant uses the camera only when you choose to capture a receipt draft or a local journal photo.",
          "photosPermission": "Pplant lets you choose a receipt photo only when you save it as a local draft."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Pplant uses the camera to capture local journal photos inside the create journal screen."
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
